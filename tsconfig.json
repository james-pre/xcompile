{
	"compilerOptions": {
		"module": "NodeNext",
		"target": "ES2022",
		"outDir": "dist",
		"lib": ["ESNext"],
		"moduleResolution": "NodeNext",
		"rootDir": "src",
		"declaration": true,
		"strict": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"],
	"typedocOptions": {
		"entryPoints": ["./src/index.ts"],
		"out": "docs",
		"name": "XCompile"
	}
}
